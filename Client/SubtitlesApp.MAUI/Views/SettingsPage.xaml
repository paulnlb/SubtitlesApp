<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:viewModels="clr-namespace:SubtitlesApp.ViewModels"
  xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
  xmlns:customControls="clr-namespace:SubtitlesApp.CustomControls"
  x:Class="SubtitlesApp.Views.SettingsPage"
  x:DataType="viewModels:SettingsViewModel"
  Title="Settings"
>
  <ContentPage.Resources>
    <ResourceDictionary>
      <Style TargetType="Entry">
        <Setter Property="Margin" Value="0, 0, 0, 20" />
      </Style>
      <Style TargetType="Label">
        <Setter Property="VerticalOptions" Value="Center" />
      </Style>
      <Style x:Key="ShowButtonStyle" TargetType="customControls:StateIconButton">
        <Setter Property="Padding" Value="2" />
        <Setter Property="HeightRequest" Value="35" />
        <Setter Property="WidthRequest" Value="35" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="State1Icon" Value="{AppThemeBinding Dark=visibility_light.png, Light=visibility_dark.png}" />
        <Setter
          Property="State2Icon"
          Value="{AppThemeBinding Dark=visibility_off_light.png, Light=visibility_off_dark.png}"
        />
      </Style>
    </ResourceDictionary>
    <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
  </ContentPage.Resources>

  <VerticalStackLayout Margin="20,30" Spacing="16">
    <!-- Transcription -->
    <Label Text="Transcription" FontAttributes="Bold" />

    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
      <Label Grid.Row="0" Text="Model" />
      <Entry Grid.Row="0" Grid.Column="1" Text="{Binding TranscriptionModel}" />

      <Label Grid.Row="1" Text="Endpoint (optional)" />
      <Entry Grid.Row="1" Grid.Column="1" Text="{Binding TranscriptionEndpoint}" />

      <Label Grid.Row="2" Text="API key" />
      <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto">
        <Entry
          Grid.Column="0"
          IsPassword="{Binding IsTranscriptionKeyShown, Converter={x:StaticResource InvertedBoolConverter}}"
          Text="{Binding TranscriptionApiKey}"
          IsEnabled="{Binding IsTranscriptionKeyShown}"
        />
        <customControls:StateIconButton
          Grid.Column="1"
          Style="{StaticResource ShowButtonStyle}"
          IsToggled="{Binding IsTranscriptionKeyShown}"
          Command="{Binding ShowTranscriptionKeyCommand}"
        />
      </Grid>
    </Grid>

    <!-- LLM -->
    <Label Text="LLM Translation" FontAttributes="Bold" />

    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
      <Label Grid.Row="0" Text="Model" />
      <Entry Grid.Row="0" Grid.Column="1" Text="{Binding OpenAiModel}" />

      <Label Grid.Row="1" Text="Endpoint (optional)" />
      <Entry Grid.Row="1" Grid.Column="1" Text="{Binding OpenAiEndpoint}" />

      <Label Grid.Row="2" Text="API key" />
      <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto">
        <Entry
          Grid.Column="0"
          IsPassword="{Binding IsOpenAiKeyShown, Converter={x:StaticResource InvertedBoolConverter}}"
          Text="{Binding OpenAiApiKey}"
          IsEnabled="{Binding IsOpenAiKeyShown}"
        />
        <customControls:StateIconButton
          Grid.Column="1"
          Style="{StaticResource ShowButtonStyle}"
          IsToggled="{Binding IsOpenAiKeyShown}"
          Command="{Binding ShowLlmKeyCommand}"
        />
      </Grid>
    </Grid>

    <Button Text="Save" Margin="0,10,0,0" Command="{Binding SaveCommand}" IsEnabled="{Binding IsDirty}" />
  </VerticalStackLayout>
</ContentPage>
