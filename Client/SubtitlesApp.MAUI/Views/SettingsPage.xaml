<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SubtitlesApp.ViewModels"
             x:Class="SubtitlesApp.Views.SettingsPage"
             x:DataType="viewModels:SettingsViewModel"
             Title="Settings">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Entry">
                <Setter Property="Margin"
                        Value="0, 0, 0, 20"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <VerticalStackLayout Margin="20, 30">
        <Label Text="Trancription model"/>
        <Entry Text="{Binding TranscriptionModel}"/>

        <Label Text="Trancription endpoint (optional)"/>
        <Entry Text="{Binding TrancriptionEndpoint}"/>

        <Label Text="Trancription api key (optional)"/>
        <Entry Text="{Binding TrancriptionApiKey}"/>

        <Label Text="Model for online LLM translation"/>
        <Entry Text="{Binding OpenAiModel}"/>

        <Label Text="LLM OpenAi compatible endpoint (optional)"/>
        <Entry Text="{Binding OpenAiEndpoint}"/>

        <Label Text="LLM api key (optional)"/>
        <Entry Text="{Binding OpenAiApiKey}"/>

        <Button Text="Save"
                Command="{Binding SaveCommand}"/>
    </VerticalStackLayout>
</ContentPage>